{%- doc -%}
  Renders a header drawer menu triggered by the top details element.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign image_border_radius = block_settings.image_border_radius | default: 4
%}

{% style %}
  .header-drawer-shop-all {
    color: var(--xinzuo-accent-text, #1A1A1E);
    font-family: "Sen", sans-serif;
    font-weight: 700;
    font-size: 16px;
    width: 89%;
    margin: 0 auto 12px;
    text-align: center;
    background-color: var(--xinzuo-accent, #FFD380);
    border: none;
    border-radius: 6px;
    padding: 12px 6px;
    letter-spacing: 0.05em;
  }

  .header-drawer-shop-all:hover {
    background-color: var(--xinzuo-accent-hover, #FFDC99);
  }

  .header-drawer-separator {
    margin: 12px 0;
    height: 1px;
    background: linear-gradient(90deg, var(--xinzuo-gold, #D1AE6B) 0%, transparent 100%);
    border: none;
  }
{% endstyle %}

<script src="{{ 'header-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>

<header-drawer class="header-drawer {{ class }}" style="--menu-image-border-radius: {{ image_border_radius }}px;">
  <details id="Details-menu-drawer-container" class="menu-drawer-container" scroll-lock data-skip-node-update>
    <summary class="header__icon header__icon--menu header__icon--summary" aria-label="{{ 'accessibility.menu' | t }}">
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--open">
        <img src="{{ 'menu-list.svg' | file_url }}" width="20" height="20" alt="Menu">
      </span>
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div data-header-drawer class="menu-drawer color-{{ block_settings.color_scheme | default: 'background' }}">
      <!-- Header Bar -->
      <div class="header-drawer-header">
        <span class="header-drawer-close" onclick="this.closest('details').open = false">
          <button class="button button-unstyled close-button" type="button" aria-label="{{ 'actions.close' | t }}">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <span>CLOSE</span>
        </span>
        <span class="header-drawer-action">
          {% render 'search', style: 'default' %}
        </span>
      </div>

      <a class="header-drawer-shop-all" href="/collections/all-products">SHOP ALL</a>

      <nav class="menu-drawer__navigation">
        <ul class="menu-drawer__menu has-submenu" role="list">
          {% for link in linklist.links %}
            {% if link.title == "Logo" %}{% continue %}{% endif %}

            <li class="header-category-li">
              {% if link.links.size > 0 %}
                <div class="header-category" onclick="headerCategoryOpen({{ forloop.index }}, event)">
                  <span>{{ link.title | escape }}</span>
                  <span class="header-category-icon">
                    <svg class="header-category-icon--closed" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5.5 3L9.5 7L5.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <svg class="header-category-icon--open" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M11 5.5L7 9.5L3 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>

                <div class="header-category-div header-category-div-{{ forloop.index }} xz-drawer-type-grid">
                  {% for sublink in link.links %}
                    {% assign collection_handle = sublink.url | split: '/' | last %}
                    {% assign collection = collections[collection_handle] %}

                    {% if link.title contains 'Series' or link.title contains 'SHOP BY SERIES' %}
                      {% render 'xz-series-tile', url: sublink.url, image: collection.featured_image, label: sublink.title %}
                    {% else %}
                      {% render 'xz-type-tile', collection: collection, type_label: sublink.title %}
                    {% endif %}
                  {% endfor %}

                  {% if link.title == "KNIVES" or link.title == "ACCESSORIES" %}
                    <a class="header-view-all" href="{{ link.url }}">
                      VIEW ALL {{ link.title }} 
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M5 15L15 5" stroke="currentColor" stroke-width="1.5"/><path d="M6.875 5H15V13.125" stroke="currentColor" stroke-width="1.5"/></svg>
                    </a>
                  {% endif %}
                </div>
              {% else %}
                <a href="{{ link.url }}" class="header-category header-category--link">
                  <span>{{ link.title | escape }}</span>
                </a>
              {% endif %}
            </li>
          {% endfor %}

          <li class="header-category-li header-drawer-separator"></li>
          <li class="header-category-li"><a href="/pages/reviews" class="header-category header-category--link"><span>Reviews</span></a></li>
          <li class="header-category-li"><a href="/pages/contact" class="header-category header-category--link"><span>Contact Us</span></a></li>
        </ul>
      </nav>

      <!-- Utility Links -->
      {% if data_header_drawer_type == 'mobile-drawer' %}
        <div class="menu-drawer__utility-links">
          {% render 'drawer-localization' %}
        </div>
      {% endif %}

      <div class="header-drawer-closediv">
        <span class="header-drawer-closebtn" onclick="this.closest('details').open = false">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M16.875 10H3.125" stroke="#828282" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8.75 4.375L3.125 10L8.75 15.625" stroke="#828282" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>GO BACK</span>
        </span>
      </div>
    </div>

    <div class="menu-drawer__backdrop" onclick="this.previousElementSibling.querySelector('details').open = false"></div>
  </details>
</header-drawer>